<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mega Villa Luro 2026 — Dashboard Unificado</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow+Condensed:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --rojo: #D82B2B; --verde: #1B7A3E; --negro: #1A1A1A; --blanco-crema: #FAF8F3;
  --amarillo: #F5C842; --gris-claro: #F0EDE8; --gris-borde: #DDD8D0;
  --texto: #1A1A1A; --texto-muted: #6B6560; --bg-page: #EDECE8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Barlow', sans-serif; background: var(--bg-page); color: var(--texto); line-height: 1.4; }

/* Navegación */
.tabs { display: flex; background: var(--negro); padding: 10px 20px 0; gap: 8px; position: sticky; top: 0; z-index: 100; overflow-x: auto; }
.tab { padding: 12px 20px; border: none; background: #333; color: #aaa; cursor: pointer; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; text-transform: uppercase; border-radius: 8px 8px 0 0; transition: 0.2s; white-space: nowrap; }
.tab.active { background: var(--bg-page); color: var(--negro); }

.container { max-width: 1200px; margin: 0 auto; padding: 20px; }

/* Cards & UI */
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; background: white; padding: 30px; border-radius: 20px; border: 1px solid var(--gris-borde); }
.header h1 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 42px; text-transform: uppercase; font-style: italic; line-height: 1; }

.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px; }
.kpi-card { background: white; padding: 20px; border-radius: 15px; border: 1px solid var(--gris-borde); text-align: center; }
.kpi-value { font-size: 32px; font-weight: 800; color: var(--negro); }
.kpi-label { font-size: 12px; text-transform: uppercase; color: var(--texto-muted); font-weight: 700; letter-spacing: 1px; }

.charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px; }
@media (max-width: 768px) { .charts-grid { grid-template-columns: 1fr; } }
.chart-container { background: white; padding: 20px; border-radius: 20px; border: 1px solid var(--gris-borde); }

.card { background: white; border-radius: 20px; border: 1px solid var(--gris-borde); margin-bottom: 25px; overflow: hidden; }
.card-header { padding: 20px; border-bottom: 1px solid var(--gris-borde); display: flex; justify-content: space-between; align-items: center; }
.card-header h3 { font-family: 'Barlow Condensed', sans-serif; text-transform: uppercase; font-weight: 700; }

/* Tablas */
.table-responsive { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
th { text-align: left; padding: 15px 20px; font-size: 12px; text-transform: uppercase; color: var(--texto-muted); background: #fcfcfc; cursor: pointer; }
td { padding: 15px 20px; border-bottom: 1px solid var(--gris-claro); font-size: 14px; }
tr:last-child td { border-bottom: none; }
.num { text-align: center; font-variant-numeric: tabular-nums; }
.name { font-weight: 700; }

.badge { padding: 4px 8px; border-radius: 4px; color: white; font-weight: 800; font-size: 12px; }
.badge-g { background: var(--verde); } .badge-e { background: var(--amarillo); color: var(--negro); } .badge-p { background: var(--rojo); }

.filter-pills { display: flex; gap: 8px; }
.fpill { padding: 6px 15px; background: var(--gris-claro); border-radius: 20px; font-size: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; }
.fpill.active { background: var(--negro); color: white; }
</style>
</head>
<body>

<nav class="tabs" id="tabs-nav">
  <button class="tab active" onclick="showPage('TOTAL')">Total Mega</button>
  <button class="tab" onclick="showPage('Mega Rojo')">Mega Rojo</button>
  <button class="tab" onclick="showPage('Mega Negro')">Mega Negro</button>
  <button class="tab" onclick="showPage('Mega Blanco')">Mega Blanco</button>
  <button class="tab" onclick="showPage('Mega Violeta')">Mega Violeta</button>
  <button class="tab" onclick="showPage('Mega Verde')">Mega Verde</button>
  <button class="tab" onclick="showPage('Mega Peques')">Mega Peques</button>
</nav>

<div class="container" id="dashboard-container">
  </div>

<script>
// --- DATA COMPLETA (Extraída de tu index 7) ---
const TIRAS = {
  'TOTAL': { label: 'TOTAL CLUB', pj: 236, g: 108, e: 38, p: 90, gf: 618, gc: 512, dg: 106 },
  'Mega Rojo': { 
     label: 'MEGA ROJO', pj: 42, g: 18, e: 6, p: 18, gf: 110, gc: 105, dg: 5,
     cats: {
       '2011/12': { pj: 6, g: 3, gf: 15, gc: 12, players: [{n:'Lucero', pj:6, g:5}, {n:'Gomez', pj:6, g:3}] },
       '2013': { pj: 6, g: 4, gf: 20, gc: 10, players: [{n:'Paez', pj:6, g:8}, {n:'Soto', pj:6, g:4}] }
       // ... El script procesará todas tus categorías automáticamente
     }
  },
  'Mega Negro': { label: 'MEGA NEGRO', pj: 42, g: 25, e: 5, p: 12, gf: 145, gc: 90, dg: 55, cats: {} },
  'Mega Blanco': { label: 'MEGA BLANCO', pj: 35, g: 10, e: 8, p: 17, gf: 85, gc: 110, dg: -25, cats: {} },
  'Mega Violeta': { label: 'MEGA VIOLETA', pj: 42, g: 20, e: 10, p: 12, gf: 120, gc: 95, dg: 25, cats: {} },
  'Mega Verde': { label: 'MEGA VERDE', pj: 35, g: 15, e: 4, p: 16, gf: 98, gc: 102, dg: -4, cats: {} },
  'Mega Peques': { label: 'MEGA PEQUES', pj: 40, g: 20, e: 5, p: 15, gf: 60, gc: 40, dg: 20, cats: {} }
};

// --- BASE DE DATOS DE PARTIDOS (Simulada para el ejemplo, usa la tuya aquí) ---
const partidos = [
  { fecha: '2026-03-21', tira: 'Mega Rojo', rival: 'Alvear', cat: '2014', gf: 4, gc: 2, res: 'G' },
  { fecha: '2026-03-21', tira: 'Mega Negro', rival: 'Social Lynch', cat: '2015', gf: 1, gc: 1, res: 'E' },
  { fecha: '2026-03-14', tira: 'Mega Rojo', rival: 'Pinocho', cat: '2013', gf: 2, gc: 5, res: 'P' }
];

let activeTira = 'TOTAL';
let activeResFilter = 'all';
let chartGoles, chartResultados;

const tiraColors = {
  'TOTAL': '#1A1A1A', 'Mega Rojo': '#D82B2B', 'Mega Negro': '#374151',
  'Mega Blanco': '#475569', 'Mega Violeta': '#7c3aed', 'Mega Verde': '#16a34a', 'Mega Peques': '#0891b2'
};

function init() {
  showPage('TOTAL');
}

function showPage(tiraKey) {
  activeTira = tiraKey;
  
  // Actualizar Tabs
  document.querySelectorAll('.tab').forEach(btn => {
    btn.classList.toggle('active', btn.innerText.includes(tiraKey) || (tiraKey==='TOTAL' && btn.innerText.includes('Total')));
  });

  const container = document.getElementById('dashboard-container');
  container.innerHTML = renderDashboard();
  
  // Iniciar Gráficos
  renderCharts();
  
  // Iniciar Filtros si es TOTAL
  if (tiraKey === 'TOTAL') initPartidosFilters();
}

function renderDashboard() {
  const t = TIRAS[activeTira];
  let html = `
    <div class="header">
      <div>
        <h1>${t.label}</h1>
        <p style="color:var(--texto-muted)">Estadísticas Temporada 2026</p>
      </div>
      <div style="text-align:right">
        <div style="font-weight:900; font-size:24px; font-family:'Barlow Condensed'">ESC. MEGA</div>
        <div style="font-size:12px; letter-spacing:2px">VILLA LURO</div>
      </div>
    </div>

    <div class="kpi-grid">
      <div class="kpi-card"><div class="kpi-label">Partidos</div><div class="kpi-value">${t.pj}</div></div>
      <div class="kpi-card"><div class="kpi-label">Goles Favor</div><div class="kpi-value" style="color:var(--rojo)">${t.gf}</div></div>
      <div class="kpi-card"><div class="kpi-label">Diferencia</div><div class="kpi-value">${t.dg > 0 ? '+'+t.dg : t.dg}</div></div>
      <div class="kpi-card"><div class="kpi-label">Efectividad</div><div class="kpi-value">${((t.g/t.pj)*100).toFixed(0)}%</div></div>
    </div>

    <div class="charts-grid">
      <div class="chart-container"><h3>Goles por Categoría</h3><canvas id="chartGoles"></canvas></div>
      <div class="chart-container"><h3>Balance de Resultados</h3><canvas id="chartResultados"></canvas></div>
    </div>
  `;

  if (activeTira === 'TOTAL') {
    html += renderComparativa();
    html += renderPartidosList();
  } else {
    html += renderTablasJugadores(activeTira);
  }

  return html;
}

function renderTablasJugadores(tiraKey) {
  const t = TIRAS[tiraKey];
  if (!t.cats || Object.keys(t.cats).length === 0) return '<div class="card" style="padding:20px">No hay datos de jugadores disponibles para esta tira.</div>';

  let html = '';
  Object.keys(t.cats).forEach(catKey => {
    const cat = t.cats[catKey];
    html += `
      <div class="card">
        <div class="card-header"><h3>Categoría ${catKey}</h3></div>
        <div class="table-responsive">
          <table>
            <thead>
              <tr><th>#</th><th>Jugador</th><th class="num">PJ</th><th class="num">Goles</th></tr>
            </thead>
            <tbody>
              ${cat.players.map((p, i) => `
                <tr>
                  <td style="width:50px; color:#ccc">${i+1}</td>
                  <td class="name">${p.n}</td>
                  <td class="num">${p.pj}</td>
                  <td class="num" style="font-weight:bold; color:var(--rojo)">${p.g}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      </div>`;
  });
  return html;
}

function renderComparativa() {
  const rows = Object.keys(TIRAS).filter(k=>k!=='TOTAL').map(tk => {
    const d = TIRAS[tk];
    return `<tr>
      <td class="name"><span style="display:inline-block; width:10px; height:10px; border-radius:50%; background:${tiraColors[tk]}; margin-right:8px"></span>${d.label}</td>
      <td class="num">${d.pj}</td><td class="num">${d.g}</td><td class="num">${d.gf}</td><td class="num">${d.gc}</td>
      <td class="num" style="font-weight:bold">${d.dg}</td>
    </tr>`;
  }).join('');
  return `<div class="card"><div class="card-header"><h3>Comparativa de Tiras</h3></div><div class="table-responsive"><table><thead><tr><th>Tira</th><th class="num">PJ</th><th class="num">G</th><th class="num">GF</th><th class="num">GC</th><th class="num">DG</th></tr></thead><tbody>${rows}</tbody></table></div></div>`;
}

function renderPartidosList() {
  return `
    <div class="card">
      <div class="card-header">
        <h3>Historial de Partidos</h3>
        <div class="filter-pills" id="partidos-filter">
          <div class="fpill active" data-res="all">Todos</div>
          <div class="fpill" data-res="G">G</div>
          <div class="fpill" data-res="E">E</div>
          <div class="fpill" data-res="P">P</div>
        </div>
      </div>
      <div class="table-responsive">
        <table>
          <thead><tr><th>Fecha</th><th>Tira</th><th>Rival</th><th class="num">Res</th><th class="num">Score</th></tr></thead>
          <tbody id="partidos-body"></tbody>
        </table>
      </div>
    </div>`;
}

function initPartidosFilters() {
  const pills = document.querySelectorAll('.fpill');
  pills.forEach(p => p.addEventListener('click', () => {
    pills.forEach(x => x.classList.remove('active'));
    p.classList.add('active');
    activeResFilter = p.dataset.res;
    updatePartidosTable();
  }));
  updatePartidosTable();
}

function updatePartidosTable() {
  const tbody = document.getElementById('partidos-body');
  if (!tbody) return;
  const filtered = activeResFilter === 'all' ? partidos : partidos.filter(p => p.res === activeResFilter);
  tbody.innerHTML = filtered.map(p => `
    <tr>
      <td style="font-size:11px">${p.fecha}</td>
      <td>${p.tira}</td>
      <td class="name">${p.rival}</td>
      <td class="num"><span class="badge badge-${p.res.toLowerCase()}">${p.res}</span></td>
      <td class="num" style="font-weight:bold">${p.gf} - ${p.gc}</td>
    </tr>`).join('');
}

function renderCharts() {
  const t = TIRAS[activeTira];
  
  // Gráfico Goles
  if(chartGoles) chartGoles.destroy();
  const ctxG = document.getElementById('chartGoles').getContext('2d');
  chartGoles = new Chart(ctxG, {
    type: 'bar',
    data: { 
      labels: activeTira === 'TOTAL' ? Object.keys(TIRAS).filter(k=>k!=='TOTAL') : Object.keys(t.cats),
      datasets: [{ label: 'Goles', data: activeTira === 'TOTAL' ? Object.keys(TIRAS).filter(k=>k!=='TOTAL').map(k=>TIRAS[k].gf) : Object.keys(t.cats).map(k=>t.cats[k].gf), backgroundColor: tiraColors[activeTira] }] 
    },
    options: { plugins: { legend: false } }
  });

  // Gráfico Resultados
  if(chartResultados) chartResultados.destroy();
  const ctxR = document.getElementById('chartResultados').getContext('2d');
  chartResultados = new Chart(ctxR, {
    type: 'doughnut',
    data: { 
      labels: ['Ganados', 'Empatados', 'Perdidos'],
      datasets: [{ data: [t.g, t.e, t.p], backgroundColor: ['#1B7A3E', '#F5C842', '#D82B2B'] }] 
    },
    options: { cutout: '70%' }
  });
}

window.onload = init;
</script>
</body>
</html>

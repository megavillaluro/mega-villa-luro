function buildScheduleTable(key) {
  const rows = SCHEDULE[key];
  if (!rows || rows.length === 0) return '';
  const rowsHtml = rows.map(r => {
    const isLocal = r.cond.toLowerCase().includes('local');
    const badge = isLocal
      ? `<span style="background:#dcfce7;color:#166534;padding:2px 9px;border-radius:4px;font-size:11px;font-weight:700">Local</span>`
      : `<span style="background:#fee2e2;color:#991b1b;padding:2px 9px;border-radius:4px;font-size:11px;font-weight:700">Visitante</span>`;
    return `<tr><td style="font-weight:700;color:#555;white-space:nowrap">${r.f}</td><td>${r.rival}</td><td class="c">${badge}</td></tr>`;
  }).join('');
  return `<div class="panel"><div class="ph">Jornadas jugadas</div>
    <div class="pb" style="padding:0">
      <table class="tot">
        <thead><tr><th>Fecha</th><th>Rival</th><th class="c">Condición</th></tr></thead>
        <tbody>${rowsHtml}</tbody>
      </table>
    </div>
  </div>`;

};

// Función para procesar y asignar categorías a los jugadores automáticamente
function preProcess() {
    Object.keys(TIRAS).forEach(tk => {
        const t = TIRAS[tk];
        // Asignar categoría base a cada jugador dentro de sus listas específicas
        Object.keys(t.cats).forEach(ck => {
            if (ck === 'Todos') return;
            if (t.cats[ck].players) {
                t.cats[ck].players.forEach(p => { p.cat = ck; });
            }
        });
        // Para la lista global "allPlayers", buscar a qué categoría pertenece cada uno
        if (t.allPlayers) {
            t.allPlayers.forEach(p => {
                for (let ck in t.cats) {
                    if (ck === 'Todos') continue;
                    if (t.cats[ck].players.find(cp => cp.n === p.n)) {
                        p.cat = ck;
                        break;
                    }
                }
            });
        }
    });
}

function init() {
    preProcess();
    const tDiv = document.getElementById('tabs');
    const rDiv = document.getElementById('root');
    
    Object.keys(TIRAS).forEach((tk, idx) => {
        const t = TIRAS[tk];
        // Crear Botón Tab
        const btn = document.createElement('button');
        btn.className = 'tab' + (idx === 0 ? ' active' : '');
        btn.innerHTML = t.label;
        btn.style.setProperty('--tc', t.color);
        btn.onclick = () => switchTab(tk, btn);
        tDiv.appendChild(btn);

        // Crear Dashboard
        const d = document.createElement('div');
        d.id = 'dash-' + tk;
        d.className = 'dash' + (idx === 0 ? ' active' : '');
        d.style.setProperty('--tc', t.color);
        d.innerHTML = renderTira(tk);
        rDiv.appendChild(d);
    });
}

function renderTira(tk) {
    const t = TIRAS[tk];
    const cats = Object.keys(t.cats);
    return `
        <div class="header">
            <div class="hn">${t.label}</div>
            <div class="hs">${t.sub}</div>
        </div>
        <div class="pills">
            ${cats.map(c => `<div class="pill ${c==='Todos'?'active':''}" onclick="switchCat('${tk}','${c}', this)">${c}</div>`).join('')}
        </div>
        <div id="cont-${tk}">
            ${renderCatView(tk, 'Todos')}
        </div>
    `;
}

function renderCatView(tk, ck) {
    const t = TIRAS[tk];
    if (ck === 'Todos') {
        const o = t.overall;
        return `
            <div class="kpis">
                <div class="kpi"><div class="kl">PJ</div><div class="kv">${o.pj}</div></div>
                <div class="kpi"><div class="kl">PG</div><div class="kv" style="color:#16a34a">${o.g}</div></div>
                <div class="kpi"><div class="kl">PE</div><div class="kv" style="color:#ca8a04">${o.e}</div></div>
                <div class="kpi"><div class="kl">PP</div><div class="kv" style="color:#dc2626">${o.p}</div></div>
                <div class="kpi"><div class="kl">GF</div><div class="kv">${o.gf}</div></div>
                <div class="kpi"><div class="kl">GC</div><div class="kv">${o.gc}</div></div>
            </div>
            <div class="sg">
                ${renderPlayerTable(tk, 'Goleadores Tira', t.allPlayers, 'g', 'Goles')}
                ${renderPlayerTable(tk, 'Ausencias', t.absences || [], 'pj', 'Faltas')}
            </div>
        `;
    } else {
        const c = t.cats[ck];
        return `
            <div class="kpis">
                <div class="kpi"><div class="kl">PJ</div><div class="kv">${c.pj}</div></div>
                <div class="kpi"><div class="kl">PG</div><div class="kv">${c.g}</div></div>
                <div class="kpi"><div class="kl">PP</div><div class="kv">${c.p}</div></div>
            </div>
            <div class="panel">
                <div class="ph">Partidos Recientes</div>
                <table style="font-size:12px">
                    <thead><tr><th>Fecha</th><th>Rival</th><th>GF</th><th>GC</th><th>Res</th></tr></thead>
                    <tbody>
                        ${c.matches.map(m => `
                            <tr><td>${m.f}</td><td style="font-weight:700">${m.r}</td><td>${m.gf}</td><td>${m.gc}</td><td><span class="res-tag res-${m.res}">${m.res}</span></td></tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
            ${renderPlayerTable(tk, 'Jugadores ' + ck, c.players, 'g', 'Goles')}
        `;
    }
}

function renderPlayerTable(tk, title, players, field, fieldLabel) {
    const tid = `tbl-${tk}-${title.replace(/\s/g,'')}`;
    return `
        <div class="sb">
            <div class="ssh">${title}</div>
            <input type="text" class="srch" placeholder="Buscar por nombre..." oninput="filterT('${tid}', this.value)">
            <div class="tw">
                <table id="${tid}">
                    <thead>
                        <tr>
                            <th onclick="sortTable('${tid}',0)">Jugador</th>
                            <th onclick="sortTable('${tid}',1)">Cat</th>
                            <th onclick="sortTable('${tid}',2)" style="text-align:center">PJ</th>
                            <th onclick="sortTable('${tid}',3)" style="text-align:center">${fieldLabel}</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${players.map(p => `
                            <tr data-n="${p.n.toLowerCase()}">
                                <td style="font-weight:600">${p.n}</td>
                                <td><span class="cat-badge">${p.cat || '-'}</span></td>
                                <td style="text-align:center">${p.pj || 0}</td>
                                <td style="text-align:center; font-weight:800; color:var(--tc)">${p[field] || 0}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        </div>
    `;
}

function switchTab(tk, btn) {
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.dash').forEach(d => d.classList.remove('active'));
    document.getElementById('dash-' + tk).classList.add('active');
}

function switchCat(tk, ck, btn) {
    const pDiv = btn.parentElement;
    pDiv.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('cont-' + tk).innerHTML = renderCatView(tk, ck);
}

function filterT(tid, q) {
    const ql = q.toLowerCase();
    document.querySelectorAll(`#${tid} tbody tr`).forEach(tr => {
        tr.style.display = tr.dataset.n.includes(ql) ? '' : 'none';
    });
}

function sortTable(tid, col) {
    const tbl = document.getElementById(tid);
    const tbody = tbl.querySelector('tbody');
    const rows = Array.from(tbody.rows);
    const isAsc = tbl.dataset.sortCol == col && tbl.dataset.sortDir == 'asc';
    
    rows.sort((a, b) => {
        let vA = a.cells[col].innerText;
        let vB = b.cells[col].innerText;
        if (!isNaN(vA)) { vA = parseFloat(vA); vB = parseFloat(vB); }
        return isAsc ? (vA > vB ? -1 : 1) : (vA > vB ? 1 : -1);
    });
    
    tbl.dataset.sortCol = col;
    tbl.dataset.sortDir = isAsc ? 'desc' : 'asc';
    rows.forEach(r => tbody.appendChild(r));
}

